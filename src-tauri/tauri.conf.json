{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "polaris",
  "version": "0.1.0",
  "identifier": "com.polaris.app",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run build && cargo build --manifest-path src-tauri/Cargo.toml --release --bin polaris-todo-mcp --bin polaris-requirements-mcp --bin polaris-scheduler-mcp",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Polaris",
        "width": 1200,
        "height": 800,
        "decorations": false,
        "hiddenTitle": true,
        "devtools": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "target/release/polaris-todo-mcp",
      "target/release/polaris-requirements-mcp",
      "target/release/polaris-scheduler-mcp"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/polaris-octopus.svg",
      "icons/polaris-commander.svg",
      "icons/polaris-brain.svg"
    ]
  }
}
